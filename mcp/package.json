{
  "name": "@devdigest/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local MCP server (stdio) exposing DevDigest's reviewer to any MCP host. Talks to the DevDigest HTTP API only — no DB, no server imports.",
  "scripts": {
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src",
    "purity:check": "node scripts/purity-check.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dependency-cruiser": "^16.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
